#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @DP4W_FILEVERSION_COMMAS@
 PRODUCTVERSION @DP4W_PRODUCTVERSION_COMMAS@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName", "@DP4W_COMPANY_NAME@\0"
      VALUE "FileDescription", "@DP4W_FILE_DESCRIPTION@\0"
      VALUE "FileVersion", "@DP4W_FILE_VERSION_STR@\0"
      VALUE "InternalName", "@DP4W_INTERNAL_NAME@\0"
      VALUE "LegalCopyright", "@DP4W_LEGAL_COPYRIGHT@\0"
      VALUE "OriginalFilename", "@DP4W_ORIGINAL_FILENAME@\0"
      VALUE "ProductName", "@DP4W_PRODUCT_NAME@\0"
      VALUE "ProductVersion", "@DP4W_PRODUCT_VERSION_STR@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
